# FoG Detection web viewer configuration.
#
# FoG Detection is a single Next.js app that serves both the browser UI and the
# backend API. When the frontend and backend run on the same machine (the
# default), the browser calls its own same-origin API and none of these
# variables are required.

# Backend API base URL used by the browser.
# Leave empty for the same-machine setup.
# Set it only when the backend runs on a different machine, e.g.:
# NEXT_PUBLIC_FOGDET_BACKEND_URL=https://fogdet-api.example.com
NEXT_PUBLIC_FOGDET_BACKEND_URL=

# Optional minimal UI.
# 0 = full UI (default). 1 = single-video workflow that hides camera recording,
# folder batching, and hand-target controls.
NEXT_PUBLIC_FOGDET_BASIC_UI=0

# Comma-separated browser origins allowed to call the backend API.
# Only needed when the backend runs on a different machine than the frontend.
# Set this on the backend, not in the browser bundle.
# Supports exact origins and wildcard subdomains (e.g. https://*.example.com).
FOGDET_ALLOWED_ORIGINS=http://127.0.0.1:4001,http://localhost:4001

# Optional backend storage overrides.
# Defaults: processed runs under output/, uploads under input/.
# FOGDET_RUNS_ROOT=output
# FOGDET_UPLOADS_ROOT=input
